VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Blog content import (scripts/import-blog-posts.ts only — never ship to the browser):
# SUPABASE_URL can be omitted if VITE_SUPABASE_URL is set.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
#   Dashboard → Project Settings → API → service_role (secret)

# Together AI key is set as a Supabase secret (not needed in .env):
#   supabase secrets set TOGETHER_API_KEY=your_key
# Edge Function URLs are derived automatically: ${VITE_SUPABASE_URL}/functions/v1/{function-name}

VITE_GA_MEASUREMENT_ID=

# GA4 Data API (server-side — set as Supabase secrets):
#   supabase secrets set GA_PROPERTY_ID=your_ga4_property_id
#   supabase secrets set GA_SERVICE_ACCOUNT_KEY='{"client_email":"...","private_key":"..."}'
